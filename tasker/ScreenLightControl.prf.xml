<?xml version="1.0" encoding="utf-8"?>
<TaskerData sr="" dvi="1" tv="6.2">
  <Profile sr="prof0" ve="2">
    <cdate>1690000000000</cdate>
    <edate>1690000000000</edate>
    <id>1</id>
    <mid0>1</mid0>
    <mid1>2</mid1>
    <nme>Screen Light Control</nme>

    <!-- TRIGGER: Display ON -->
    <Event sr="con0" ve="2">
      <code>64</code>
    </Event>

    <!-- TASK: Light ON -->
    <Task sr="task0">
      <id>1</id>
      <nme>Light ON</nme>
      <Action sr="act0" ve="7">
        <code>339</code>
        <Str sr="arg0" ve="3">http://YOUR_HA_IP:8123/api/services/light/turn_on</Str>
        <Str sr="arg1" ve="3">application/json</Str>
        <Str sr="arg2" ve="3">{"entity_id": "YOUR_ENTITY_ID"}</Str>
        <Str sr="arg3" ve="3">Authorization: Bearer YOUR_HA_TOKEN</Str>
        <Int sr="arg4" val="0"/>
        <Str sr="arg5" ve="3"/>
        <Str sr="arg6" ve="3"/>
      </Action>
    </Task>

    <!-- TASK: Light OFF (runs when Display OFF) -->
    <Task sr="task1">
      <id>2</id>
      <nme>Light OFF</nme>
      <Action sr="act0" ve="7">
        <code>339</code>
        <Str sr="arg0" ve="3">http://YOUR_HA_IP:8123/api/services/light/turn_off</Str>
        <Str sr="arg1" ve="3">application/json</Str>
        <Str sr="arg2" ve="3">{"entity_id": "YOUR_ENTITY_ID"}</Str>
        <Str sr="arg3" ve="3">Authorization: Bearer YOUR_HA_TOKEN</Str>
        <Int sr="arg4" val="0"/>
        <Str sr="arg5" ve="3"/>
        <Str sr="arg6" ve="3"/>
      </Action>
    </Task>

  </Profile>
</TaskerData>

